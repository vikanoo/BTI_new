    {
      "parameters": {
        "jsCode": "const buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst base64 = buffer.toString('base64');\nconst mimeType = $input.item.binary?.data?.mimeType || 'image/jpeg';\nreturn [{\n  json: { plan_base64: base64, plan_mime: mimeType },\n  binary: $input.item.binary\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
        480
      ],
      "id": "ee000000-0000-0000-0000-000000000000",
      "name": "Извлечь base64 из плана"
    },
    {
      "parameters": {
        "jsCode": "const base64 = $('Извлечь base64 из плана').item.json.plan_base64;\nconst mime = $('Извлечь base64 из плана').item.json.plan_mime;\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\nconst prompt = 'Проанализируй план квартиры на изображении. Определи все помещения (жилые комнаты, кухня, ванная, туалет, коридор, балкон, кладовая). Ответ верни ТОЛЬКО в формате JSON без markdown: объект с полем rooms — массив объектов с полями id (строка room_N), name (название помещения на русском), region_percent (объект с x1, y1, x2, y2 — координаты области от 0 до 1).';\nconst requestBody = {\n  contents: [{parts: [{text: prompt},{inline_data:{mime_type:mime,data:base64}}]}],\n  generationConfig: {temperature: 0.1}\n};\nreturn [{json: {requestBody, chatId}}];"
      },
